# Production environment configuration
# BUG: Production credentials in a file committed to git!
# BUG: Should use AWS Secrets Manager or Vault

APP_ENV=production
# BUG: Debug mode enabled in production
DEBUG=true
LOG_LEVEL=DEBUG

# BUG: Same weak secret key as dev
SECRET_KEY=my-super-secret-jwt-key-dont-share

# Database - Production RDS
DB_HOST=dummy-infra-prod-db.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
# BUG: Production DB password in plain text in config file
DB_PASSWORD=Passw0rd123!
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# BUG: SSL mode disabled for production DB connection
DB_SSL_MODE=disable

# Redis - Production ElastiCache
REDIS_HOST=dummy-infra-prod-redis.abc123.cache.amazonaws.com
REDIS_PORT=6379
# BUG: No password for production Redis
REDIS_PASSWORD=

# JWT
JWT_SECRET=my-super-secret-jwt-key-dont-share
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# AWS Production credentials
# BUG: PRODUCTION AWS credentials in plaintext config file
AWS_ACCESS_KEY_ID=AKIAI44QH8DHBEXAMPLE
AWS_SECRET_ACCESS_KEY=je7MtGbClwBF/2Zp9Utk/h3yCo8nvbEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET=dummy-infra-prod-assets

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
# BUG: Production SendGrid API key in plain text
SMTP_PASSWORD=SG.prod-sendgrid-api-key-1234567890abcdef

# Twilio Production
# BUG: Production Twilio credentials committed
TWILIO_ACCOUNT_SID=TWILIO-FAKE-PROD-SID-FOR-TESTING-ONLY
TWILIO_AUTH_TOKEN=TWILIO-FAKE-PROD-TOKEN-FOR-TESTING-ONLY
TWILIO_FROM_NUMBER=+18005551234

# Service URLs
USER_SERVICE_URL=http://user-service:8001
ORDER_SERVICE_URL=http://order-service:8002
AUTH_SERVICE_URL=http://auth-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004

# Feature flags
ENABLE_RATE_LIMITING=false
ENABLE_CIRCUIT_BREAKER=false
ENABLE_DISTRIBUTED_TRACING=false

# CORS
# BUG: All origins allowed in production
ALLOWED_ORIGINS=*
