# Development environment configuration
# BUG: .env files committed to git with real credentials

# Application
APP_ENV=development
# BUG: Debug mode in dev is fine but this file gets used in prod too
DEBUG=true
LOG_LEVEL=DEBUG

# BUG: Secret key too short and predictable
SECRET_KEY=dev-secret-key

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
# BUG: Weak password
DB_PASSWORD=Passw0rd123!
# BUG: Connection pool too small
DB_POOL_SIZE=2
# BUG: Connection pool max overflow set incorrectly
DB_MAX_OVERFLOW=1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# BUG: No Redis password set
REDIS_PASSWORD=

# JWT
# BUG: Same JWT secret as production
JWT_SECRET=my-super-secret-jwt-key-dont-share
JWT_ALGORITHM=HS256
# BUG: Expiry way too long
JWT_EXPIRY_DAYS=30

# AWS
# BUG: AWS credentials in .env file
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET=dummy-infra-dev-assets

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@dummycompany.com
# BUG: Real SMTP password committed
SMTP_PASSWORD=smtp-password-123!

# Twilio
# BUG: Real API credentials committed
TWILIO_ACCOUNT_SID=TWILIO-FAKE-SID-FOR-TESTING-ONLY
TWILIO_AUTH_TOKEN=TWILIO-FAKE-TOKEN-FOR-TESTING-ONLY
TWILIO_FROM_NUMBER=+15555555555

# Service URLs (for API gateway)
# BUG: Wrong port for user service (5001 vs 8001)
USER_SERVICE_URL=http://user-service:5001
ORDER_SERVICE_URL=http://order-service:8002
AUTH_SERVICE_URL=http://auth-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004

# Feature flags
# BUG: Feature flags hardcoded in env file instead of feature flag service
ENABLE_RATE_LIMITING=false
ENABLE_CIRCUIT_BREAKER=false
ENABLE_DISTRIBUTED_TRACING=false
